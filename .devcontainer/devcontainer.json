{
  "name": "AWS-Master-Template-Workbench",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true
    },
    "ghcr.io/devcontainers/features/terraform:1": {
      "version": "latest",
      "tflint": "latest",
      "terragrunt": "latest"
    },
    "ghcr.io/devcontainers/features/aws-cli:1": {},
    "ghcr.io/devcontainers/features/python:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts",
      "pnpmVersion": "latest",
      "nvmInstallPath": "/home/vscode/.nvm"
    },
    "ghcr.io/devcontainers/features/java:1": {
      "version": "21",
      "installMaven": "true",
      "jdkDistro": "amzn"
    },
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "version": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terraform.languageServer.enable": true,
        "terraform.validation.enableLocalCodeCheck": true,
        "editor.defaultFormatter": "hashicorp.terraform",
        "files.exclude": {
          "JUCE/": true,
          "**/Builds/": true,
          "**/.vs/": true
        },
        "terminal.integrated.defaultProfile.linux": "zsh",
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
        "python.terminal.activateEnvInCurrentTerminal": true,
        "python.analysis.importFormat": "relative",
        "python.analysis.extraPaths": [
          "${workspaceFolder}/services/wilderchess/src"
        ],
        // Tells VS Code to look for the venv uv creates
        "python.venvPath": "${workspaceFolder}/.venv",
        "editor.formatOnSave": true,
        "editor.bracketPairColorization.enabled": true,
        "editor.guides.bracketPairs": "active",
        // --- Language Specific Formatters ---
        "[terraform]": {
          "editor.defaultFormatter": "hashicorp.terraform"
        },
        "[terraform-vars]": {
          "editor.defaultFormatter": "hashicorp.terraform"
        },
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter",
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        },
        "[java]": {
          "editor.defaultFormatter": "redhat.java"
        },
        "[json]": {
          "editor.defaultFormatter": "vscode.json-language-features"
        },
        "[jsonc]": {
          "editor.defaultFormatter": "vscode.json-language-features"
        },
        "[yaml]": {
          "editor.defaultFormatter": "redhat.vscode-yaml"
        },
        "[shellscript]": {
          "editor.defaultFormatter": "foxundermoon.shell-format"
        },
        "[toml]": {
          "editor.defaultFormatter": "tamasfe.even-better-toml"
        },
        "[dockerfile]": {
          "editor.defaultFormatter": "ms-azuretools.vscode-docker"
        },
        "[markdown]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        }
      },
      "extensions": [
        "tamasfe.even-better-toml",
        "hashicorp.terraform",
        "anton-prazdnichnykh.tflint",
        "amazonwebservices.aws-toolkit-vscode",
        "usernamehw.errorlens",
        "github.vscode-github-actions",
        "vscjava.vscode-java-pack",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter", // Added for Python Ctrl+S
        "esbenp.prettier-vscode", // Added for JSON/YAML/MD
        "foxundermoon.shell-format", // Added for .sh
        "ms-azuretools.vscode-docker", // Added for Docker
        "redhat.vscode-yaml" // Added for better YAML validation
      ]
    }
  },
  "containerEnv": {
    "WAYLAND_DISPLAY": "",
    "DISPLAY": ""
  },
  "mounts": [
    {
      "source": "${localEnv:HOME}${localEnv:USERPROFILE}/.aws",
      "target": "/home/vscode/.aws",
      "type": "bind"
    },
    // PERSISTENT VOLUMES: This prevents re-downloading Python and Node packages
    {
      "source": "uv-cache",
      "target": "/home/vscode/.cache/uv",
      "type": "volume"
    },
    {
      "source": "pnpm-store",
      "target": "/home/vscode/.local/share/pnpm",
      "type": "volume"
    }
  ],
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "remoteUser": "vscode"
}